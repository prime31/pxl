{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug hello-world",
            "program": "${workspaceFolder}/zig-out/bin/hello-world",
            "args": [
                "src/main.zig"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Launch Last Target",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/zig-out/bin/${input:zigLastTarget}",
            "args": [],
        }
    ],
    "inputs": [
        {
            "id": "zigLastTarget",
            "type": "command",
            "command": "zig.build.getLastTargetOrPrompt"
        }
    ]
}